{
  "name": "@ginga-ui/core",
  "version": "0.13.3",
  "private": false,
  "description": "brand-new UI component library for web",
  "keywords": [
    "component",
    "library",
    "react",
    "ui"
  ],
  "homepage": "https://github.com/newt239/ginga-ui#readme",
  "bugs": {
    "url": "https://github.com/newt239/ginga-ui/issues"
  },
  "author": {
    "name": "newt239",
    "email": "ysti2019.win2020.st@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/newt239/ginga-ui.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "*.css"
  ],
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./variables.css": "./dist/variables.css"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "build:fast": "tsdown --no-dts"
  },
  "dependencies": {
    "@ginga-ui/utils": "workspace:*",
    "react-aria-components": "1.18.0"
  },
  "devDependencies": {
    "react": "19.2.7"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
