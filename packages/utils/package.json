  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "build:fast": "tsdown --no-dts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.84",
    "@ai-sdk/google": "3.0.82",
    "@ai-sdk/openai": "3.0.71",
    "ai": "6.0.205",
    "chroma-js": "3.2.0",
    "zod": "4.4.3"
  }
}
