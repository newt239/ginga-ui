{
  "name": "ginga-ui",
  "version": "1.0.0",
  "private": true,
  "description": "brand-new UI component library for web",
  "keywords": [
    "component",
    "library",
    "react",
    "ui"
  ],
  "homepage": "https://github.com/newt239/ginga-ui#readme",
  "bugs": {
    "url": "https://github.com/newt239/ginga-ui/issues"
  },
  "author": {
    "name": "newt239",
    "email": "ysti2019.win2020.st@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/newt239/ginga-ui.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "setup": "corepack enable pnpm",
    "preinstall": "npx only-allow pnpm",
    "changeset-version": "changeset version",
    "changeset-publish": "changeset publish",
    "clean": "find . -type d \\( -name 'node_modules' -o -name '.turbo' -o -name 'dist' -o -name 'pnpm-lock.yaml' \\) -prune -exec rm -rf {} +",
    "dev": "turbo run dev --filter=./packages/**",
    "build": "turbo run build --filter=./packages/**",
    "build:fast": "turbo run build:fast --filter=./packages/**",
    "lint": "oxlint --type-aware --fix",
    "format": "oxfmt .",
    "stylelint": "stylelint \"./**/*.css\" --fix",
    "knip": "knip",
    "docs": "pnpm --prefix app/ginga-ui.com dev",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@storybook/addon-links": "10.5.0",
    "@storybook/builder-vite": "10.5.0",
    "@storybook/react": "10.5.0",
    "@storybook/react-vite": "10.5.0",
    "@tsdown/css": "0.22.3",
    "@types/chroma-js": "3.1.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "chromatic": "18.0.1",
    "knip": "6.26.0",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "react": "19.2.7",
    "react-aria-components": "1.19.0",
    "storybook": "10.5.0",
    "stylelint": "17.14.0",
    "stylelint-config-recess-order": "7.7.0",
    "stylelint-config-standard": "40.0.0",
    "tsdown": "0.22.3",
    "turbo": "2.9.18",
    "typescript": "7.0.2",
    "vite": "8.1.4"
  },
  "engines": {
    "node": "26.x"
  },
  "packageManager": "pnpm@11.7.0"
}
